---
import Base from "../../layouts/Base.astro";
import { u, CARE_LABELS } from "../../consts";
import specimens from "../../data/specimens.json";
import { resolveMineral } from "../../data/minerals";
import { resolveFossil } from "../../data/fossils";
import { PERIODS, ageToPct, ageMidpoint } from "../../data/geotime";
import SpecimenCard from "../../components/SpecimenCard.astro";

// Mohs positions for the hardness bar reference marks.
const MOHS_REF = [
  { n: 1, m: "Talc" },
  { n: 2.5, m: "Fingernail" },
  { n: 3, m: "Calcite" },
  { n: 5.5, m: "Knife blade" },
  { n: 7, m: "Quartz" },
  { n: 10, m: "Diamond" },
];

export function getStaticPaths() {
  return specimens.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;

// Locality confidence -> honest qualifier shown next to the locality.
const LOC_QUALIFIER = {
  confirmed: "",
  likely: "Most likely source",
  tentative: "Best estimate",
  assorted: "Assorted rough",
};
const locQualifier = LOC_QUALIFIER[item.localityConfidence] ?? "";

// Similar pieces: same mineral species first, then same line, excluding self and
// sold pieces. Up to 3.
const sameKey = (s) => s.slug !== item.slug && s.status !== "sold";
const similar = [
  ...specimens.filter((s) => sameKey(s) && s.line === item.line && s.species === item.species),
  ...specimens.filter((s) => sameKey(s) && s.line === item.line && s.species !== item.species),
].filter((s, i, arr) => arr.findIndex((x) => x.slug === s.slug) === i).slice(0, 3);

const lineLabel = {
  minerals: "Minerals",
  fossils: "Fossils & Shells",
  lava: "Lava Lamps",
  coins: "Coins & Currency",
}[item.line] || "Collection";
const lineHref = u({ minerals: "minerals", fossils: "fossils", lava: "lava-lamps", coins: "coins" }[item.line] || "");
const statusLabel = { available: "Available", reserved: "Reserved", sold: "Sold" }[item.status];
const active = item.line === "lava" ? "lava" : item.line;
const care = (item.care || []).map((c) => CARE_LABELS[c] || c);

// Resolve real mineralogy for the piece (minerals only). Drives the data panel
// and the "hardness on the Mohs scale" bar.
const resolved = item.line === "minerals" ? resolveMineral(item.species) : null;
const mineral = resolved?.mineral || null;
// Parse a hardness like "3.5–4" to a midpoint for the bar position.
const hardnessNum = mineral
  ? (() => {
      const nums = (mineral.hardness.match(/[\d.]+/g) || []).map(Number);
      return nums.length ? nums.reduce((a, b) => a + b, 0) / nums.length : null;
    })()
  : null;

// Resolve fossil reference + geologic-time marker (fossils only).
const fossil = item.line === "fossils" ? resolveFossil(item) : null;
const agePct = fossil && item.ageMin != null
  ? ageToPct(ageMidpoint(item.ageMax != null ? (item.ageMin + item.ageMax) / 2 : item.ageMin))
  : null;
const ageStartPct = fossil && item.ageMax != null ? ageToPct(item.ageMax) : null;
const ageEndPct = fossil && item.ageMin != null ? ageToPct(item.ageMin) : null;

// Product schema: price, availability, and image so each piece is eligible for
// product rich results and readable by AI shopping answers.
const availability = {
  available: "https://schema.org/InStock",
  reserved: "https://schema.org/PreOrder",
  sold: "https://schema.org/SoldOut",
}[item.status] || "https://schema.org/InStock";

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": item.name,
  "description": item.description,
  "image": new URL(u(item.image), Astro.site).href,
  "category": lineLabel,
  "offers": {
    "@type": "Offer",
    "price": item.price,
    "priceCurrency": "USD",
    "availability": availability,
    "url": new URL(Astro.url.pathname, Astro.site).href,
    "seller": { "@type": "Store", "name": "Grimsley Mineral Co." },
  },
};
---
<Base title={`${item.name} — Grimsley Mineral Co.`} description={item.description} active={active} schema={productSchema}>
  <div class="detail">
    <div class="gallery">
      <div class="main"><img src={u(item.image)} alt={item.name} /></div>
    </div>
    <div class="buy">
      <div class="crumb"><a href={lineHref}>{lineLabel}</a> / {item.species}</div>
      <h1>{item.name}</h1>
      <span class={`status ${item.status}`}>{statusLabel}</span>
      <div class="price">${item.price}.00{item.priceNote && <span style="font-size:15px;color:var(--muted);"> {item.priceNote}</span>}</div>
      <p class="desc">{item.description}</p>

      {item.asIdentified && (
        <p class="desc" style="font-size:14px;color:var(--gold);border-left:2px solid var(--gold);padding-left:12px;">Identified from research and inspection, not lab-confirmed. We are verifying this one before it lists at full price, in keeping with our honest-grading promise.</p>
      )}

      <div class="cta">
        {item.status === "available" && (
          <button
            class="btn btn-dark js-reserve"
            data-slug={item.slug}
            data-name={item.name}
            data-price={item.price}
          >{item.line === "lava" ? "Add to inquiry list" : "Reserve this piece"}</button>
        )}
        {item.status === "reserved" && <a class="btn btn-ghost" href={u("contact")}>Ask about this piece</a>}
        {item.status === "sold" && <a class="btn btn-ghost" href={lineHref}>See similar pieces</a>}
        {item.status === "available" && <a class="btn btn-ghost" href={u("contact")}>Ask a question</a>}
      </div>

      <div class="boothnote"><b>Aug 6–9 at the 127:</b> cash and in person at the booth. Reserve here to hold this piece for pickup, or buy online after the sale.</div>

      <dl class="spec">
        <div class="r"><dt>Species</dt><dd>{mineral ? <a href={u(`mineral/${mineral.key}`)}>{item.species}</a> : item.species}</dd></div>
        <div class="r"><dt>Locality</dt><dd>{item.locality}{locQualifier && <span class="loc-q">{locQualifier}</span>}</dd></div>
        <div class="r"><dt>Size class</dt><dd>{item.sizeClass}</dd></div>
        <div class="r"><dt>Dimensions</dt><dd>{item.dimensions}</dd></div>
        {item.provenance && <div class="r"><dt>Provenance</dt><dd>{item.provenance}</dd></div>}
        <div class="r"><dt>Condition</dt><dd>{item.condition}</dd></div>
        <div class="r"><dt>Treatment</dt><dd>{item.treatment}</dd></div>
        {care.length > 0 && <div class="r"><dt>Care</dt><dd>{care.join(" · ")}</dd></div>}
        {item.fluorescent && <div class="r"><dt>Fluorescence</dt><dd>Reacts under UV</dd></div>}
        {item.worksStatus && <div class="r"><dt>Working status</dt><dd>{item.worksStatus}</dd></div>}
        <div class="r"><dt>Catalog</dt><dd>{item.slug.toUpperCase().replace(/-/g, " ")}</dd></div>
      </dl>

      {item.localityNote && (
        <div class="locnote">
          <span class="pin">◈</span>
          <div>
            <span class="lh">On the locality</span>
            <p>{item.localityNote}</p>
            {item.localityConfidence && item.localityConfidence !== "confirmed" && (
              <p class="hedge">We compare our pieces against documented localities to place a likely source. On this one we are not calling it as certain, just our best read from the material.</p>
            )}
          </div>
        </div>
      )}

      <div class="guarantee">
        <h4>Authenticity guaranteed</h4>
        <p>Every piece is genuine and described honestly, with condition, treatment, and any care needs disclosed right here. Where an ID is not yet lab-confirmed, we say so. Shipped insured. Questions before you reserve? Just ask.</p>
      </div>
    </div>
  </div>

  {mineral && (
    <section class="mineralpanel">
      <div class="wrap">
        <div class="mp-head">
          <div class="k">Mineral data</div>
          <h2>{mineral.name}{resolved?.variety && <span class="var"> · {resolved.variety}</span>}</h2>
          <p>{mineral.about}</p>
        </div>

        <div class="mp-grid">
          <div class="mp-facts">
            <div class="f"><span class="l">Chemical formula</span><span class="v" set:html={mineral.formulaHtml} /></div>
            <div class="f"><span class="l">Mineral class</span><span class="v">{mineral.mineralClass}</span></div>
            <div class="f"><span class="l">Crystal system</span><span class="v">{mineral.crystalSystem}</span></div>
            <div class="f"><span class="l">Luster</span><span class="v">{mineral.luster}</span></div>
            <div class="f"><span class="l">Streak</span><span class="v">{mineral.streak}</span></div>
          </div>

          <div class="mp-hardness">
            <span class="l">Hardness · Mohs {mineral.hardness}</span>
            <div class="bar">
              {hardnessNum && <span class="fill" style={`width:${(hardnessNum / 10) * 100}%`}></span>}
              {hardnessNum && <span class="dot" style={`left:${(hardnessNum / 10) * 100}%`}></span>}
              {MOHS_REF.map((r) => (
                <span class="tick" style={`left:${(r.n / 10) * 100}%`} title={`${r.n} — ${r.m}`}></span>
              ))}
            </div>
            <div class="scaleref">
              {MOHS_REF.map((r) => (
                <span style={`left:${(r.n / 10) * 100}%`}>{r.n} {r.m}</span>
              ))}
            </div>
          </div>
        </div>

        {mineral.fluorescence && mineral.fluorescence !== "Not fluorescent." && mineral.fluorescence !== "Not notably fluorescent." && (
          <div class="mp-fluor"><b>Under UV.</b> {mineral.fluorescence}</div>
        )}

        <div class="mp-foot">
          <p><b>Handling:</b> {mineral.care}</p>
          <a class="mp-link" href={u(`mineral/${mineral.key}`)}>Full {mineral.name} reference and pieces in stock →</a>
        </div>
      </div>
    </section>
  )}

  {fossil && (
    <section class="mineralpanel">
      <div class="wrap">
        <div class="mp-head">
          <div class="k">Fossil data</div>
          <h2>{fossil.name}</h2>
          <p>{fossil.about}</p>
        </div>

        <div class="mp-grid">
          <div class="mp-facts">
            <div class="f"><span class="l">What it is</span><span class="v">{fossil.classification}</span></div>
            <div class="f"><span class="l">Geologic age</span><span class="v">{item.ageLabel}</span></div>
            <div class="f"><span class="l">Period</span><span class="v">{item.period}{item.epoch ? ` · ${item.epoch}` : ""}</span></div>
            <div class="f"><span class="l">Formation / origin</span><span class="v">{item.formation}</span></div>
          </div>

          <div class="mp-hardness">
            <span class="l">Where it sits in geologic time</span>
            <div class="timeline">
              {PERIODS.map((p) => {
                const l = ageToPct(p.start);
                const w = ageToPct(p.end) - ageToPct(p.start);
                return <span class="band" style={`left:${l}%;width:${w}%`} title={`${p.name} (${p.start}–${p.end} mya)`}><i>{p.short}</i></span>;
              })}
              {ageStartPct != null && ageEndPct != null && (
                <span class="agespan" style={`left:${ageStartPct}%;width:${Math.max(0.8, ageEndPct - ageStartPct)}%`}></span>
              )}
              {agePct != null && <span class="agedot" style={`left:${agePct}%`}></span>}
            </div>
            <div class="tl-ends"><span>541 mya</span><span>today</span></div>
            <p class="tl-note">The marker shows this piece against the Phanerozoic, the last 541 million years of complex life.</p>
          </div>
        </div>

        <div class="mp-foot">
          <p><b>Handling:</b> {fossil.care}</p>
          <a class="mp-link" href={u("fossils")}>See all fossils in stock →</a>
        </div>
      </div>
    </section>
  )}

  {similar.length > 0 && (
    <section class="learn">
      <div class="wrap">
        <div class="sec-top">
          <div class="k">More from the collection</div>
          <h2>Pieces you might pair with this</h2>
        </div>
        <div class="grid">
          {similar.map((s) => <SpecimenCard item={s} />)}
        </div>
      </div>
    </section>
  )}
</Base>
