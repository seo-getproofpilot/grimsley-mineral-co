---
import Base from "../../layouts/Base.astro";
import { u, CARE_LABELS } from "../../consts";
import specimens from "../../data/specimens.json";

export function getStaticPaths() {
  return specimens.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const lineLabel = {
  minerals: "Minerals",
  fossils: "Fossils & Shells",
  lava: "Lava Lamps",
  coins: "Coins & Currency",
}[item.line] || "Collection";
const lineHref = u({ minerals: "minerals", fossils: "fossils", lava: "lava-lamps", coins: "coins" }[item.line] || "");
const statusLabel = { available: "Available", reserved: "Reserved", sold: "Sold" }[item.status];
const active = item.line === "lava" ? "lava" : item.line;
const care = (item.care || []).map((c) => CARE_LABELS[c] || c);

// Product schema: price, availability, and image so each piece is eligible for
// product rich results and readable by AI shopping answers.
const availability = {
  available: "https://schema.org/InStock",
  reserved: "https://schema.org/PreOrder",
  sold: "https://schema.org/SoldOut",
}[item.status] || "https://schema.org/InStock";

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": item.name,
  "description": item.description,
  "image": new URL(u(item.image), Astro.site).href,
  "category": lineLabel,
  "offers": {
    "@type": "Offer",
    "price": item.price,
    "priceCurrency": "USD",
    "availability": availability,
    "url": new URL(Astro.url.pathname, Astro.site).href,
    "seller": { "@type": "Store", "name": "Grimsley Mineral Co." },
  },
};
---
<Base title={`${item.name} — Grimsley Mineral Co.`} description={item.description} active={active} schema={productSchema}>
  <div class="detail">
    <div class="gallery">
      <div class="main"><img src={u(item.image)} alt={item.name} /></div>
    </div>
    <div class="buy">
      <div class="crumb"><a href={lineHref}>{lineLabel}</a> / {item.species}</div>
      <h1>{item.name}</h1>
      <span class={`status ${item.status}`}>{statusLabel}</span>
      <div class="price">${item.price}.00{item.priceNote && <span style="font-size:15px;color:var(--muted);"> {item.priceNote}</span>}</div>
      <p class="desc">{item.description}</p>

      {item.asIdentified && (
        <p class="desc" style="font-size:14px;color:var(--gold);border-left:2px solid var(--gold);padding-left:12px;">Identified from research and inspection, not lab-confirmed. We are verifying this one before it lists at full price, in keeping with our honest-grading promise.</p>
      )}

      <div class="cta">
        {item.status === "available" && item.line !== "lava" && <a class="btn btn-dark" href={u("contact")}>Reserve for pickup</a>}
        {item.status === "available" && item.line === "lava" && <a class="btn btn-dark" href={u("contact")}>Inquire / commission</a>}
        {item.status === "reserved" && <a class="btn btn-ghost" href={u("contact")}>Ask about this piece</a>}
        {item.status === "sold" && <a class="btn btn-ghost" href={lineHref}>See similar pieces</a>}
        {item.status === "available" && <a class="btn btn-ghost" href={u("contact")}>Inquire</a>}
      </div>

      <div class="boothnote"><b>Aug 6–9 at the 127:</b> cash and in person at the booth. Reserve here to hold this piece for pickup, or buy online after the sale.</div>

      <dl class="spec">
        <div class="r"><dt>Species</dt><dd>{item.species}</dd></div>
        <div class="r"><dt>Locality</dt><dd>{item.locality}</dd></div>
        <div class="r"><dt>Size class</dt><dd>{item.sizeClass}</dd></div>
        <div class="r"><dt>Dimensions</dt><dd>{item.dimensions}</dd></div>
        {item.provenance && <div class="r"><dt>Provenance</dt><dd>{item.provenance}</dd></div>}
        <div class="r"><dt>Condition</dt><dd>{item.condition}</dd></div>
        <div class="r"><dt>Treatment</dt><dd>{item.treatment}</dd></div>
        {care.length > 0 && <div class="r"><dt>Care</dt><dd>{care.join(" · ")}</dd></div>}
        {item.fluorescent && <div class="r"><dt>Fluorescence</dt><dd>Reacts under UV</dd></div>}
        {item.worksStatus && <div class="r"><dt>Working status</dt><dd>{item.worksStatus}</dd></div>}
        <div class="r"><dt>Catalog</dt><dd>{item.slug.toUpperCase().replace(/-/g, " ")}</dd></div>
      </dl>

      <div class="guarantee">
        <h4>Authenticity guaranteed</h4>
        <p>Every piece is genuine and described honestly, with condition, treatment, and any care needs disclosed right here. Where an ID is not yet lab-confirmed, we say so. Shipped insured. Questions before you reserve? Just ask.</p>
      </div>
    </div>
  </div>
</Base>
