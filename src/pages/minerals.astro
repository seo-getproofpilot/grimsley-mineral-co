---
import Base from "../layouts/Base.astro";
import { u, TIERS } from "../consts";
import SpecimenCard from "../components/SpecimenCard.astro";
import specimens from "../data/specimens.json";
const items = specimens.filter((s) => s.line === "minerals");
const sizes = [...new Set(items.map((s) => s.sizeClass))].filter((s) => s !== "Assorted").sort();
const species = [...new Set(items.map((s) => s.species))].sort();
const country = (loc) => (loc || "").split(",").pop().trim();
const countries = [...new Set(items.map((s) => country(s.locality)).filter((c) => c && c !== "request"))].sort();
const byTier = (t) => items.filter((s) => s.tier === t);

// Origins: group pieces by country (last segment of the locality), ordered
// west-to-east by average longitude so the strip reads like a world line.
const countryOf = (loc) =>
  (loc || "").replace(/\)/g, "").split(/,|\(/).map((s) => s.trim()).filter(Boolean).pop() || "Unknown";
const originMap = {};
for (const s of items) {
  const c = countryOf(s.locality);
  (originMap[c] ||= { country: c, pieces: [], lng: [] });
  originMap[c].pieces.push(s);
  if (s.coords) originMap[c].lng.push(s.coords.lng);
}
const origins = Object.values(originMap)
  .map((o) => ({ ...o, avgLng: o.lng.length ? o.lng.reduce((a, b) => a + b, 0) / o.lng.length : 0 }))
  .sort((a, b) => a.avgLng - b.avgLng);
const originCount = origins.length;
---
<Base title="Minerals — Grimsley Mineral Co." active="minerals">
  <div class="pagehead">
    <div class="inner">
      <div class="crumb"><a href={u("")}>Home</a> / Minerals</div>
      <h1>Minerals</h1>
      <p>From a two-dollar bin rock to a documented cabinet specimen, sorted so you know which is which. The bin is fun and affordable. The collector and vault pieces carry real localities, honest condition, and where we know it, where they came from.</p>
      <div class="boothnote" style="margin-top:22px;"><b>Aug 6–9 at the 127:</b> cash and in person at the booth. Reserve a piece here to hold it for pickup, or buy online after the sale.</div>
    </div>
  </div>
  <section>
    <div class="wrap">
      <div class="filters">
        <div class="grp">
          <span class="lbl">Tier</span>
          <button class="chip on" data-filter="tier" data-value="all">All</button>
          <button class="chip" data-filter="tier" data-value="vault">Vault</button>
          <button class="chip" data-filter="tier" data-value="collector">Collector</button>
          <button class="chip" data-filter="tier" data-value="bin">Bin</button>
        </div>
        <span class="sep"></span>
        <div class="grp">
          <span class="lbl">Size</span>
          <button class="chip on" data-filter="size" data-value="all">All</button>
          {sizes.map((s) => <button class="chip" data-filter="size" data-value={s}>{s}</button>)}
        </div>
        <span class="sep"></span>
        <div class="grp">
          <span class="lbl">Locality</span>
          <button class="chip on" data-filter="locality" data-value="all">All</button>
          {countries.map((c) => <button class="chip" data-filter="locality" data-value={c}>{c}</button>)}
        </div>
        <span class="count" id="count"></span>
      </div>

      {TIERS.map((t) => (
        <div class="tier" data-tier-section={t.key}>
          <div class="th">
            <h2>{t.label}</h2>
            <span class="n">{t.note}</span>
          </div>
          <div class="grid">
            {byTier(t.key).map((item) => <SpecimenCard item={item} />)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="origins">
    <div class="wrap">
      <div class="sec-top">
        <div class="k">Sourced from around the world</div>
        <h2>Where these pieces came from</h2>
        <p>We trace each piece to its most likely source by comparing it against documented localities. {originCount} countries are represented in the minerals here, from the Americas east to Asia. Where we are not certain of the exact source, we say so on the piece.</p>
      </div>
      <div class="worldline">
        {origins.map((o) => (
          <div class="origin">
            <div class="oc">{o.country}</div>
            <div class="on">{o.pieces.length} piece{o.pieces.length > 1 ? "s" : ""}</div>
            <div class="op">
              {o.pieces.map((p) => (
                <a href={u(`specimen/${p.slug}`)}>{p.name}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const cards = Array.from(document.querySelectorAll(".card"));
      const sections = Array.from(document.querySelectorAll(".tier"));
      const countEl = document.getElementById("count");
      const state = { size: "all", tier: "all", locality: "all" };

      function apply() {
        let shown = 0;
        cards.forEach((c) => {
          const okSize = state.size === "all" || c.dataset.size === state.size;
          const okTier = state.tier === "all" || c.dataset.tier === state.tier;
          const okLoc = state.locality === "all" || (c.dataset.locality || "").includes(state.locality);
          const show = okSize && okTier && okLoc;
          c.classList.toggle("hide", !show);
          if (show) shown++;
        });
        sections.forEach((sec) => {
          const visible = sec.querySelectorAll(".card:not(.hide)").length;
          sec.classList.toggle("hide", visible === 0);
        });
        countEl.textContent = shown + " of " + cards.length + " specimens";
      }

      document.querySelectorAll(".chip").forEach((chip) => {
        chip.addEventListener("click", () => {
          const f = chip.dataset.filter;
          state[f] = chip.dataset.value;
          document.querySelectorAll('.chip[data-filter="' + f + '"]').forEach((c) => c.classList.remove("on"));
          chip.classList.add("on");
          apply();
        });
      });
      apply();
    })();
  </script>
</Base>
