---
import Base from "../layouts/Base.astro";
import SpecimenCard from "../components/SpecimenCard.astro";
import specimens from "../data/specimens.json";
import { u } from "../consts";

const featuredMinerals = specimens.filter((s) => s.line === "minerals" && s.featured).slice(0, 6);
const mapDest = "5521%20South%20York%20Highway%2C%20Grimsley%2C%20TN%2038565";
---
<Base>
  <!-- HERO -->
  <div class="hero">
    <div class="bg" style={`background-image:url('${u("img/lifestyle/cabinet.jpg")}');background-position:center 30%;`}></div>
    <div class="scrim"></div>
    <div class="inner">
      <div class="kicker">A family collection · Grimsley, Tennessee</div>
      <h1>Natural history, one specimen at a time.</h1>
      <p>Display-grade minerals, fossils, and one-of-a-kind pieces, chosen for quality and described honestly. Grand opening at the Highway 127 Yard Sale, then online.</p>
      <div class="btns">
        <a class="btn btn-gold" href={u("minerals")}>Browse the collection</a>
        <a class="btn btn-line" href={u("standard")}>How we grade</a>
      </div>
    </div>
  </div>

  <!-- TRUST BAR -->
  <div class="trustbar">
    <div class="row">
      <span>Authenticity guaranteed</span>
      <span>Honest condition on every piece</span>
      <span>Size &amp; scale on every listing</span>
      <span>Ships insured</span>
    </div>
  </div>

  <!-- CATEGORIES -->
  <section>
    <div class="wrap">
      <div class="sec-top">
        <div class="k">The Collection</div>
        <h2>Five lines, one shelf</h2>
        <p>From a two-dollar fossil for a kid to a cabinet-grade centerpiece, and a wall of lava lamps besides.</p>
      </div>
      <div class="cats">
        <a class="cat" href={u("minerals")}><img src={u("img/lifestyle/cabinet.jpg")} alt="Mineral specimens" /><div class="lab"><div class="n">Minerals</div><div class="m">Amethyst · Fluorite · Rutile</div></div></a>
        <a class="cat solid" href={u("fossils")}><div class="lab"><div class="n">Fossils &amp; Shells</div><div class="m">Fish plates · Pearls · Coral</div></div></a>
        <a class="cat" href={u("lava-lamps")}><img src={u("img/lifestyle/lava-collection.jpg")} alt="Lava lamp collection" /><div class="lab"><div class="n">Lava Lamps</div><div class="m">Hand-built · One of one</div></div></a>
        <a class="cat" href={u("nails")}><img src={u("img/lifestyle/nails.jpg")} alt="Bugged Out Nails" /><div class="lab"><div class="n">Bugged Out Nails</div><div class="m">Hand-painted press-ons</div></div></a>
        <a class="cat solid" href={u("coins")}><div class="lab"><div class="n">Coins &amp; Currency</div><div class="m">Silver · Gold · Old money</div></div></a>
      </div>
    </div>
  </section>

  <!-- FEATURED -->
  <section style="padding-top:0;">
    <div class="wrap">
      <div class="sec-top">
        <div class="k">Just added</div>
        <h2>Newly cataloged specimens</h2>
        <p>Each piece is photographed as it is, with its locality and size on the label.</p>
      </div>
      <div class="grid">
        {featuredMinerals.map((item) => <SpecimenCard item={item} />)}
      </div>
      <div class="center-cta"><a class="btn btn-dark" href={u("minerals")}>View all minerals</a></div>
    </div>
  </section>

  <!-- PRICE BANDS -->
  <section style="padding-top:0;">
    <div class="wrap">
      <div class="sec-top">
        <div class="k">Every budget</div>
        <h2>Shop by price</h2>
      </div>
      <div class="bands">
        <a class="bandcard" href={u("minerals")}><div class="p">Under $25</div><div class="l">Tumbles, small clusters, and bulk fossils. Great starters and gifts.</div><div class="g">Shop the bin →</div></a>
        <a class="bandcard" href={u("minerals")}><div class="p">$25 – $150</div><div class="l">Display-grade minerals and fossils with real localities, sized and documented.</div><div class="g">Shop collector →</div></a>
        <a class="bandcard" href={u("minerals")}><div class="p">The Vault · $150+</div><div class="l">Standout specimens and one-of-a-kind lamps. The best of what we've cataloged.</div><div class="g">Enter the vault →</div></a>
      </div>
    </div>
  </section>

  <!-- STANDARD -->
  <section class="trust">
    <div class="wrap">
      <div class="sec-top"><div class="k">Our Standard</div><h2>How we grade, and what we promise</h2></div>
      <div class="cols">
        <div class="c"><div class="n"><span class="b"></span>Genuine &amp; identified</div><p>Every piece is a real, correctly identified specimen. Treated stones, like heat-set citrine, are labeled as treated, never passed off as natural.</p></div>
        <div class="c"><div class="n"><span class="b"></span>Honest condition</div><p>If a piece has a chip or a repair, we tell you exactly what and where. No surprises when it arrives.</p></div>
        <div class="c"><div class="n"><span class="b"></span>Documented locality</div><p>Real localities on every label, from the mine to the country, as specific as the piece allows.</p></div>
        <div class="c"><div class="n"><span class="b"></span>True photography</div><p>Photos are lit to show real color and luster, with size and scale on every listing.</p></div>
      </div>
    </div>
  </section>

  <!-- LAVA -->
  <div class="feature dark" id="lava">
    <div class="split">
      <div class="txt">
        <div class="k">Light · Hand-built</div>
        <h2>Functional art, one of one.</h2>
        <p>Alongside our collection, we hand-sculpt custom lava lamps from Apoxie clay, like our Venom-inspired symbiote lamp. Own the piece that exists, or commission a new one in your colors and form.</p>
        <div class="btns"><a class="btn btn-gold" href={u("lava-lamps")}>See the lamps</a><a class="btn btn-line" href={u("lava-lamps")}>Commission a piece</a></div>
      </div>
      <div class="pic"><img src={u("img/lifestyle/lava-collection.jpg")} alt="Lava lamp collection" /></div>
    </div>
  </div>

  <!-- NAILS -->
  <div class="feature pink" id="nails">
    <div class="split">
      <div class="pic"><img src={u("img/lifestyle/nails-gothic.jpg")} alt="Hand-painted press-on nails" /></div>
      <div class="txt">
        <div class="k">Bugged Out Nails</div>
        <h2>Hand-painted press-ons.</h2>
        <p>Taylor's side of the shop. Custom sets, pick-and-press singles, and ready-to-ship art nails, all made to order. Browse the looks here, then order on Instagram or Facebook.</p>
        <div class="btns"><a class="btn btn-pink" href={u("nails")}>See the nails</a><a class="btn btn-pinkline" href={u("nails")}>Order on Instagram</a></div>
      </div>
    </div>
  </div>

  <!-- FIELD NOTES -->
  <section class="learn">
    <div class="wrap">
      <div class="sec-top"><div class="k">Field Notes</div><h2>Know what you're buying</h2><p>A little context makes a specimen worth more to you, and to the next person you show it to.</p></div>
      <div class="learn-grid">
        <a class="t" href={u("field-notes/how-a-specimen-earns-its-grade")}><div class="num">Guide 01</div><h3>How a specimen earns its grade</h3><p>The things that decide a piece's quality, in plain terms, from a collector's checklist.</p><span class="r">Read →</span></a>
        <a class="t" href={u("field-notes/what-a-locality-tells-you")}><div class="num">Guide 02</div><h3>What a locality tells you</h3><p>Why the mine a piece came from is part of the science, and part of the price.</p><span class="r">Read →</span></a>
        <a class="t" href={u("field-notes/what-fades-and-what-dissolves")}><div class="num">Guide 03</div><h3>What fades and what dissolves</h3><p>Which pieces fade in the sun, which dissolve in water, and how to keep a specimen at its best.</p><span class="r">Read →</span></a>
      </div>
    </div>
  </section>

  <!-- VISIT -->
  <div class="visit" id="visit">
    <div class="split">
      <div class="info">
        <div class="k">Find us in person</div>
        <h2>The 127 Yard Sale</h2>
        <div class="addr">
          <b>August 6–9, 2026</b> · Thursday through Sunday<br />
          5521 South York Hwy, Grimsley, TN 38565<br />
          On US-127, between Dollar General &amp; Taco Bros
        </div>
        <div class="btns">
          <a class="btn btn-gold" href={`https://www.google.com/maps/dir/?api=1&destination=${mapDest}`} target="_blank" rel="noopener">Get directions</a>
          <a class="btn btn-line" href={u("visit")}>Plan your visit</a>
        </div>
      </div>
      <div class="mapbox live">
        <iframe
          title="Map to 5521 South York Highway, Grimsley TN"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps?q=5521+South+York+Highway,+Grimsley,+TN+38565&output=embed"
        ></iframe>
      </div>
    </div>
  </div>
</Base>
