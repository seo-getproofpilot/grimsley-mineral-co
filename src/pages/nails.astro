---
import Base from "../layouts/Base.astro";
---
<Base title="Bugged Out Nails — Grimsley Mineral Co." active="nails">
  <div class="pagehead">
    <div class="inner">
      <div class="crumb"><a href="/">Home</a> / Bugged Out Nails</div>
      <h1>Bugged Out Nails</h1>
      <p>Taylor's hand-painted press-on nail art, from soft pink ladybug and floral sets to gothic and holiday designs. Every set is painted by hand, so no two are exactly alike. This page is here to show the work. Ordering happens over on Instagram and Facebook, where Taylor takes requests and posts new designs.</p>
    </div>
  </div>

  <div class="feature pink">
    <div class="split">
      <div class="pic"><img src="/img/lifestyle/nails-gothic.jpg" alt="Hand-painted press-on nails" /></div>
      <div class="txt">
        <div class="k">Made to order</div>
        <h2>Painted by hand, one set at a time.</h2>
        <p>Custom sets, pick-and-press singles, and ready-to-ship art nails. Send Taylor your idea and your sizes, pick a shape and length, and she paints it. Sets ship in about a week.</p>
        <div class="btns">
          <a class="btn btn-pink" href="#">Follow on Instagram</a>
          <a class="btn btn-pinkline" href="#">Message on Facebook</a>
        </div>
      </div>
    </div>
  </div>

  <section>
    <div class="wrap">
      <div class="sec-top"><div class="k">The looks</div><h2>A few recent sets</h2></div>
      <div class="grid g4">
        <div class="card"><div class="imgwrap" style="background:var(--pink-bg);"><img src="/img/lifestyle/nails.jpg" alt="Floral press-on set" style="object-fit:cover;padding:0;" /></div><div class="meta"><div class="sp">Floral &amp; Ladybug</div><div class="dims">Hand-painted · custom</div></div></div>
        <div class="card"><div class="imgwrap" style="background:var(--pink-bg);"><img src="/img/lifestyle/nails-gothic.jpg" alt="Gothic press-on set" style="object-fit:cover;padding:0;" /></div><div class="meta"><div class="sp">Gothic &amp; Holiday</div><div class="dims">Hand-painted · custom</div></div></div>
      </div>
      <div class="center-cta"><a class="btn btn-pink" href="#">See the full gallery on Instagram</a></div>
    </div>
  </section>
</Base>
