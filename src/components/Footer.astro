---
import { u, SITE, FULL_ADDRESS } from "../consts";
---
<footer class="site">
  <div class="fgrid">
    <div>
      <div class="name">Grimsley Mineral Co.</div>
      <div class="blurb">Cataloged minerals, fossils, hand-built lava lamps, and collector coins out of Grimsley, Tennessee.</div>
      <div class="pay"><span>Stripe</span><span>Square</span><span>PayPal</span><span>Zelle</span><span>Cash</span></div>
    </div>
    <div class="col">
      <h5>Shop</h5>
      <a href={u("minerals")}>Minerals</a>
      <a href={u("fossils")}>Fossils &amp; Shells</a>
      <a href={u("lava-lamps")}>Lava Lamps</a>
      <a href={u("coins")}>Coins &amp; Currency</a>
      <a href={u("nails")}>Bugged Out Nails</a>
    </div>
    <div class="col">
      <h5>Learn</h5>
      <a href={u("standard")}>Our Standard</a>
      <a href={u("authenticity")}>Authenticity &amp; Honesty</a>
      <a href={u("field-notes")}>Field Notes</a>
      <a href={u("fluorescent")}>Under the UV</a>
      <a href={u("about")}>Our Story</a>
      <a href={u("faq")}>FAQ</a>
      <a href={u("shipping")}>Shipping &amp; Returns</a>
    </div>
    <div class="col">
      <h5>Contact</h5>
      <a href={u("contact")}>Get in Touch</a>
      <a href={u("contact")}>Commission a Lamp</a>
      <a href={u("visit")}>Find the Booth</a>
    </div>
  </div>
  <div class="colo">
    <span>{FULL_ADDRESS} · <a href={`mailto:${SITE.email}`}>{SITE.email}</a></span>
    <span>© 2026 Grimsley Mineral Co.</span>
  </div>
</footer>
